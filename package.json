{
  "name": "hono-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "benchmark": "bun benchmarks/basic-load.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf build dist",
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./build --target bun",
    "start": "bun src/index.ts",
    "start:prod": "NODE_ENV=production bun src/index.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.731.1",
    "@aws-sdk/client-s3": "^3.850.0",
    "@aws-sdk/client-ses": "^3.731.1",
    "@aws-sdk/client-sns": "^3.732.0",
    "@aws-sdk/s3-request-presigner": "^3.850.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^9.10.0",
    "@sentry/tracing": "^7.120.3",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.7.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.1",
    "hono": "^4.11.4",
    "hono-injector": "^1.0.1",
    "inversify": "^6.0.1",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.20",
    "peculiar-orm": "^1.0.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "twilio": "^5.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sentry/cli": "^2.43.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.5",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "autocannon": "^8.0.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^8.0.3",
    "jiti": "^2.6.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.53.0"
  }
